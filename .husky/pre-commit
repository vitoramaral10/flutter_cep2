#!/bin/bash

# Pre-commit hook: Format Dart code before committing
echo "🔍 Formatting Dart code..."

dart format --output=none --set-exit-if-changed .

if [ $? -ne 0 ]; then
    echo ""
    echo "⚠️  Code formatting issues found and fixed."
    echo "Please review the changes and stage them again:"
    echo ""
    echo "  git add ."
    echo "  git commit -m \"your message\""
    echo ""
    exit 1
fi

exit 0
